# --- LLM Provider ---
# Required by CrewAI (unless using a different LLM provider)
OPENAI_API_KEY=your_openai_api_key_here

# --- Tool APIs ---
# Serper.dev API Key for Google Search integration (Required)
SERPER_API_KEY=your_serper_api_key_here

# Resend API Key for email dispatch (Required)
RESEND_API_KEY=your_resend_api_key_here

# --- Database ---
# If running via Docker Compose, this is handled automatically.
# Local SQLite fallback: sqlite:///leads.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/bluemountain

# --- Engine Configuration ---
# Set to true to include Seattle, Portland, Spokane, Boise
PNW_TOGGLE=false

# Max leads to draft before triggering Human-In-The-Loop dispatcher
MAX_LEADS_BATCH=100
